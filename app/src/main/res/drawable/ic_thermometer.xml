<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive-icon foreground for Free-Grilly.
    Viewport 108×108; safe zone is the centre 72×72.
    Design: diagonal BBQ probe (upper-right → lower-left) + orange arc + ember sparks.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Orange arc: centre (54,54), r=30.
        Runs counter-clockwise from ~1 o'clock (77,35) via 12→9→6 to ~7 o'clock (35,77).
        large-arc-flag=1 (>180°), sweep-flag=0 (CCW on screen).
    -->
    <path
        android:pathData="M 77,35 A 30,30 0 1 0 35,77"
        android:fillColor="#00000000"
        android:strokeColor="#FF6B2C"
        android:strokeWidth="5"
        android:strokeLineCap="round" />

    <!--
        Probe spike: tapered triangle from ferrule area to sharp tip.
        Handle/ferrule end ~(62,43); tip ~(18,89).
    -->
    <path
        android:pathData="M 57,40 L 64,47 L 20,90 Z"
        android:fillColor="#FF7A30" />

    <!--
        Handle body: rotated -45° around its centre (72,24).
        Rectangle (62,10)→(82,10)→(82,38)→(62,38) in local coords.
        After rotation: spans upper-right quadrant from ~(69,7) to ~(89,27) at clip end.
    -->
    <group
        android:pivotX="72"
        android:pivotY="24"
        android:rotation="-45">

        <!-- Dark body -->
        <path
            android:pathData="M 63,10 Q 63,8 65,8 L 79,8 Q 81,8 81,10 L 81,38 Q 81,40 79,40 L 65,40 Q 63,40 63,38 Z"
            android:fillColor="#1C1C1C" />

        <!-- Orange border -->
        <path
            android:pathData="M 63,10 Q 63,8 65,8 L 79,8 Q 81,8 81,10 L 81,38 Q 81,40 79,40 L 65,40 Q 63,40 63,38 Z"
            android:fillColor="#00000000"
            android:strokeColor="#FF6B2C"
            android:strokeWidth="2.5" />

        <!-- Slot groove -->
        <path
            android:pathData="M 66,22 L 78,22"
            android:fillColor="#00000000"
            android:strokeColor="#FF6B2C"
            android:strokeWidth="2"
            android:strokeLineCap="round" />

        <!-- Circle hole at clip end -->
        <path
            android:pathData="M 72,13 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0"
            android:fillColor="#131313" />
    </group>

    <!--
        Ferrule: small orange connector block between handle and spike.
        Rotated -45° so it aligns with the probe axis.
    -->
    <group
        android:pivotX="62"
        android:pivotY="44"
        android:rotation="-45">
        <path
            android:pathData="M 56,40 L 68,40 L 68,48 L 56,48 Z"
            android:fillColor="#FF6B2C" />
    </group>

    <!-- Ember sparks scattered in the lower-left quadrant -->
    <path android:pathData="M 40,70 m -2.5,0 a 2.5,2.5 0 1,0 5,0 a 2.5,2.5 0 1,0 -5,0"
        android:fillColor="#FF6B2C" android:fillAlpha="0.90" />
    <path android:pathData="M 33,79 m -1.8,0 a 1.8,1.8 0 1,0 3.6,0 a 1.8,1.8 0 1,0 -3.6,0"
        android:fillColor="#FF6B2C" android:fillAlpha="0.85" />
    <path android:pathData="M 47,77 m -1.2,0 a 1.2,1.2 0 1,0 2.4,0 a 1.2,1.2 0 1,0 -2.4,0"
        android:fillColor="#FF6B2C" android:fillAlpha="0.70" />
    <path android:pathData="M 37,64 m -1.0,0 a 1.0,1.0 0 1,0 2,0 a 1.0,1.0 0 1,0 -2,0"
        android:fillColor="#FF6B2C" android:fillAlpha="0.75" />
    <path android:pathData="M 27,85 m -2.0,0 a 2.0,2.0 0 1,0 4,0 a 2.0,2.0 0 1,0 -4,0"
        android:fillColor="#FF6B2C" android:fillAlpha="0.80" />
    <path android:pathData="M 44,84 m -0.8,0 a 0.8,0.8 0 1,0 1.6,0 a 0.8,0.8 0 1,0 -1.6,0"
        android:fillColor="#FF6B2C" android:fillAlpha="0.65" />
    <path android:pathData="M 24,73 m -1.3,0 a 1.3,1.3 0 1,0 2.6,0 a 1.3,1.3 0 1,0 -2.6,0"
        android:fillColor="#FF6B2C" android:fillAlpha="0.70" />

</vector>
